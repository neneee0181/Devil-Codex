{
  "name": "devil-codex",
  "version": "0.1.66",
  "private": true,
  "description": "High-fidelity multi-provider Codex desktop client",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "dev:electron": "npm run build:main && wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .",
    "build": "npm run build:renderer && npm run build:mobile && npm run build:main",
    "build:renderer": "vite build",
    "build:mobile": "vite build -c vite.mobile.config.ts",
    "build:main": "tsc -p tsconfig.electron.json",
    "start": "electron .",
    "icons": "node scripts/build-icons.cjs",
    "prepackage": "npm run icons && npm run build",
    "package": "electron-builder",
    "dist": "npm run prepackage && electron-builder",
    "dist:mac": "npm run prepackage && electron-builder --mac",
    "dist:win": "npm run prepackage && electron-builder --win",
    "postinstall": "node scripts/fix-pty.cjs"
  },
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.198",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "dotenv": "^17.4.2",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.21.0",
    "motion": "^12.40.0",
    "node-pty": "^1.1.0",
    "prism-react-renderer": "^2.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.35.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "dev.devilcodex.app",
    "productName": "Devil Codex",
    "executableName": "Devil Codex",
    "artifactName": "DevilCodex-${version}-${arch}.${ext}",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "afterSign": "build/after-sign.cjs",
    "asarUnpack": [
      "node_modules/node-pty/**",
      "node_modules/@nut-tree-fork/**",
      "node_modules/@anthropic-ai/claude-agent-sdk*/**",
      "node_modules/sharp/**",
      "node_modules/@img/**"
    ],
    "files": [
      "dist/**",
      "dist-mobile/**",
      "dist-electron/**",
      "build/icon.png",
      "build/icon.ico",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false,
      "extraResources": [
        {
          "from": "vendor/codex/codex",
          "to": "codex/codex"
        },
        {
          "from": "scripts/devil-browser-mcp.cjs",
          "to": "scripts/devil-browser-mcp.cjs"
        },
        {
          "from": "scripts/devil-computer-mcp.cjs",
          "to": "scripts/devil-computer-mcp.cjs"
        },
        {
          "from": "scripts/devil-ask-mcp.cjs",
          "to": "scripts/devil-ask-mcp.cjs"
        },
        {
          "from": "scripts/devil-subagent-mcp.cjs",
          "to": "scripts/devil-subagent-mcp.cjs"
        }
      ],
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "build/icon.ico",
          "to": "build/icon.ico"
        },
        {
          "from": "build/icon.png",
          "to": "build/icon.png"
        },
        {
          "from": "vendor/codex/codex.exe",
          "to": "codex/codex.exe"
        },
        {
          "from": "scripts/devil-browser-mcp.cjs",
          "to": "scripts/devil-browser-mcp.cjs"
        },
        {
          "from": "scripts/devil-computer-mcp.cjs",
          "to": "scripts/devil-computer-mcp.cjs"
        },
        {
          "from": "scripts/devil-ask-mcp.cjs",
          "to": "scripts/devil-ask-mcp.cjs"
        },
        {
          "from": "scripts/devil-subagent-mcp.cjs",
          "to": "scripts/devil-subagent-mcp.cjs"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowElevation": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "neneee0181",
        "repo": "Devil-Codex",
        "releaseType": "release"
      }
    ]
  }
}
